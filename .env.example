# StudyBuddy Environment Variables
# Copy this file to .env and fill in the values

# Database (for Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/studybuddy?schema=public"

# Supabase Authentication
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# OpenAI (for AI generation)
OPENAI_API_KEY=sk-your_openai_api_key

# Google Cloud Vision (for OCR)
GOOGLE_CLOUD_VISION_API_KEY=your_google_cloud_key

# Cloudflare R2 (for file storage)
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=studybuddy-files
R2_PUBLIC_URL=https://your-bucket.r2.dev

# Redis (for caching and queues)
REDIS_URL=redis://localhost:6379

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Vercel Cron (for weekly league processing)
# Generate a random string: openssl rand -hex 32
CRON_SECRET=your_random_secret_here
